{
  "expo": {
    "name": "Katkut AI",
    "slug": "katkut-ai",
    "scheme": "katkut",
    "version": "1.1.0",
    "orientation": "portrait",
    "icon": "./assets/katkutai_app_icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.katkut.app",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.katkut.app",
      "versionCode": 2,
      "adaptiveIcon": {
        "backgroundColor": "#141414",
        "foregroundImage": "./assets/katkutai_app_icon.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "extra": {
      "eas": {
        "projectId": "d4cac464-cc14-4ed0-a986-1ba1373208bc"
      }
    },
    "owner": "sanjayabhattarai",
    "plugins": [
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "KatKut needs access to your videos to build your reel. Clips stay on your device and are never uploaded."
        }
      ],
      "expo-sharing",
      [
        "expo-media-library",
        {
          "savePhotosPermission": "KatKut saves your finished reel to your gallery.",
          "isAccessMediaLocationEnabled": false
        }
      ],
      "expo-video",
      "expo-font",
      "expo-asset",
      "expo-apple-authentication",
      "./plugins/withReleaseSigning.js",
      "./plugins/withUnifiedIosSigning.js"
    ]
  }
}
